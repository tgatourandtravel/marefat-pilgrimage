# Canonical site URL (no trailing slash) — used for SEO metadata, sitemap, robots
NEXT_PUBLIC_SITE_URL=https://marefatpilgrimage.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYMENT_ADMIN_EMAIL=info@marefatpilgrimage.com

ADMIN_PASSWORD=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry error monitoring — https://sentry.io
# Create a Next.js project in Sentry, then paste the DSN below.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Generate at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
